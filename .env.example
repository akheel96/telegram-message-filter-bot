# =====================================================
# Telegram Loot Filter Bot - Environment Configuration
# =====================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# =====================================================
# REQUIRED - Must be set for bot to work
# =====================================================

# Telegram API credentials (get from https://my.telegram.org/apps)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Source channels to monitor (comma-separated channel IDs)
# Format: -1001234567890,-1009876543210
# Get IDs using: python get_ids.py
SOURCE_CHANNEL_IDS=-1001234567890

# Destination channel/chat for filtered messages
DESTINATION_CHANNEL_ID=-1009876543210

# =====================================================
# FILTERING - What messages to process
# =====================================================

# Keywords to filter messages (comma-separated, case-insensitive)
FILTER_KEYWORDS=loot,deal,offer

# Skip messages containing these sites/text (comma-separated)
SKIP_SITES_TEXT=ajio,ajiio

# Skip category/search pages (only forward single product links)
SKIP_LISTING_PAGES=false

# =====================================================
# PRODUCT EXTRACTION - E-commerce features
# =====================================================

# Enable product info extraction from URLs
ENABLE_PRODUCT_INFO=true

# Skip forwarding out-of-stock products
SKIP_OUT_OF_STOCK=true

# Enable generic HTML scraping for unknown e-commerce sites
ENABLE_GENERIC_SCRAPER=true

# Convert Amazon URLs to Indian domain
PREFER_INDIAN_URLS=true

# Highlight deals with discount above this percentage
DISCOUNT_HIGHLIGHT_THRESHOLD=50

# =====================================================
# PERFORMANCE - Speed tuning
# =====================================================

# Fast mode: Use reduced timeouts (10s max)
FAST_MODE=true

# Skip product extraction entirely for MAXIMUM SPEED (~5s)
SKIP_PRODUCT_EXTRACTION=false

# HTTP timeout in seconds (capped at 10s in fast mode)
HTTP_TIMEOUT=15

# =====================================================
# SESSION & CONNECTION
# =====================================================

SESSION_NAME=loot_filter_bot
CACHE_SIZE=1000
RECONNECT_DELAY=5
MAX_RETRIES=10

# =====================================================
# LOGGING
# =====================================================

LOG_LEVEL=INFO
